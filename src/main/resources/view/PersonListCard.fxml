<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="15" bottom="5" left="15" />
      </padding>

      <Label fx:id="urgencyLevel" text="\$urgencyLevel" />

      <HBox spacing="0.5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label"
               wrapText="true" maxWidth="1.7976931348623157E308" />

      </HBox>
      <FlowPane fx:id="symptoms" />
      <Label fx:id="ic" styleClass="cell_small_label" text="\$ic" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" />
      <Label fx:id="address" styleClass="cell_small_label" text="\$address"
             wrapText="true" maxWidth="1.7976931348623157E308" />
      <Label fx:id="email" styleClass="cell_small_label" text="\$email"
             wrapText="true" maxWidth="1.7976931348623157E308"/>
      <Label fx:id="doctorName" styleClass="cell_small_label" text="\$doctor name"
             wrapText="true" maxWidth="1.7976931348623157E308"/>
      <Label fx:id="nextOfKin" styleClass="cell_small_label" text="\$next of kin"
             wrapText="true" maxWidth="1.7976931348623157E308"/>
      <Label fx:id="nextOfKinPhone" styleClass="cell_small_label" text="\$next-of-kin phone" />
      <Label fx:id="nextOfKinRelationship" styleClass="cell_small_label" text="\$next-of-kin relationship"
             wrapText="true" maxWidth="1.7976931348623157E308"/>
      <Label fx:id="notes" text="\$notes" styleClass="cell_small_label"
             wrapText="true" maxWidth="1.7976931348623157E308" />
    </VBox>
  </GridPane>
</HBox>
